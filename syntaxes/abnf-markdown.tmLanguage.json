{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "ABNF Markdown Injection",
	"scopeName": "text.html.markdown.abnf.codeblock",
	"injectionSelector": "L:text.html.markdown",
	"patterns": [
		{
			"begin": "(^|\\G)(\\s*)(```|~~~)\\s*(?i:(abnf))\\s*$",
			"beginCaptures": {
				"3": { "name": "punctuation.definition.markdown" },
				"4": { "name": "fenced_code.block.language.markdown" }
			},
			"end": "(^|\\G)(\\2|\\s{0,3})(\\3)\\s*$",
			"endCaptures": { "3": { "name": "punctuation.definition.markdown" } },
			"contentName": "meta.embedded.block.abnf",
			"patterns": [ { "include": "source.abnf" } ]
		}
	]
}
